          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.54 13.9l-1.55.54c-.47.16-.97-.17-.97-.67V7.33c0-.52.54-.86 1-.62l5.13 2.78c.44.24.48.86.07 1.15l-3.68 3.26zM10 16.5c0-.55.45-1 1-1s1 .45 1 1v4c0 .55-.45 1-1 1s-1-.45-1-1v-4zM7.5 14.1l-3.62 1.78c-.5.25-.6.9-.2 1.28l2.13 2.13c.37.37 1 .3 1.27-.15l2.24-3.87c.27-.47-.03-1.07-.57-1.16l-1.25-.01zM6.9 11.5L3 10.38c-.53-.16-.82-.73-.62-1.24l1.04-2.83c.2-.54.82-.73 1.27-.38L9 9.1c.44.34.38 1-.1 1.26l-2 1.14zM14.3 15.76l2.24 3.87c.27.45.9.52 1.27.15l2.13-2.13c.4-.38.3-1.03-.2-1.28L16.1 14.6c-.54-.27-1.16.1-1.23.66l-.57.5z"/></svg>
        </a>
      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo">
            <img src="/logo.webp" alt="Clark Handy Solutions logo" class="footer-logo-img" />
            <span>Clark <em>Handy</em> Solutions</span>
          </a>
          <p>Professional handyman services you can trust. Serving Orange County and surrounding areas.</p>
          <div class="footer-socials">
            <a href="https://www.instagram.com/chandysolutions" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
            <a href="https://www.facebook.com/CHandySolutionsOC/" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href="https://www.tiktok.com/@Chandysolutions" target="_blank" rel="noopener" aria-label="TikTok">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
            </a>
            <a href="https://nextdoor.com/page/c-handy-solutions-pollock-id" target="_blank" rel="noopener" aria-label="Nextdoor">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.69 2 6 4.69 6 8v2.5C6 12.43 7.57 14 9.5 14H11v7c0 .55.45 1 1 1s1-.45 1-1v-7h1.5c1.93 0 3.5-1.57 3.5-3.5V8c0-3.31-2.69-6-6-6zm4 8.5c0 .83-.67 1.5-1.5 1.5H13c-.55 0-1 .45-1 1v7h0v-7c0-.55-.45-1-1-1H9.5C8.67 12 8 11.33 8 10.5V8c0-2.21 1.79-4 4-4s4 1.79 4 4v2.5z"/></svg>
            </a>
