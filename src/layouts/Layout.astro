        <li><a href="/board">Resources</a></li>
        <li><a href="/faq" class="nav-faq">FAQs</a></li>
        <li><a href="/contact" class="nav-cta">Get a Quote</a></li>
      </ul>

      <button class="nav-mobile-toggle" id="menuToggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <!-- Mobile menu -->
