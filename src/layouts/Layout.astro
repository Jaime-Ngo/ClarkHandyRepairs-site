<style>
  /* NAV */
  #navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(8,8,8,0.9);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--gold-dim);
    transition: background 0.3s;
  }

  .nav-inner {
    height: 115px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    text-decoration: none;
  }

  .nav-logo-img {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .nav-logo-text {
    font-family: var(--font-display);
    font-size: 2rem;
    letter-spacing: 0.06em;
    color: var(--light);
  }

  .nav-logo-text em {
    font-style: normal;
    color: var(--gold);
  }

  .nav-links-desktop {
    display: flex;
    align-items: center;
    gap: 2.2rem;
    list-style: none;
  }

  .nav-links-desktop a {
    font-family: var(--font-cond);
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
  }

  .nav-links-desktop a:hover { color: var(--light); }

  .nav-faq {
    text-transform: none !important;
    letter-spacing: 0.12em !important;
  }

  .nav-cta {
    color: var(--gold) !important;
    border: 1px solid var(--gold-dim);
    padding: 0.5rem 1.5rem;
    border-radius: 2px;
    transition: all 0.2s !important;
  }
  .nav-cta:hover {
    background: var(--gold) !important;
    color: var(--dark) !important;
    border-color: var(--gold) !important;
  }

  /* SERVICES DROPDOWN */
  .nav-item-dropdown {
    position: relative;
  }

  .nav-dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .nav-dropdown-chevron {
    transition: transform 0.2s ease;
    opacity: 0.6;
  }

  .nav-item-dropdown:hover .nav-dropdown-chevron {
    transform: rotate(180deg);
    opacity: 1;
  }

  .nav-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    min-width: 210px;
    flex-direction: column;
    z-index: 200;
    padding-top: 0.75rem;
  }

  .nav-dropdown-inner {
    background: var(--dark-2);
    border: 1px solid var(--gold-dim);
    border-radius: 2px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .nav-item-dropdown:hover .nav-dropdown {
    display: flex;
  }

  .nav-dropdown a {
    font-family: var(--font-cond);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted) !important;
    padding: 0.8rem 1.2rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: color 0.2s, background 0.2s;
  }
  .nav-dropdown a:last-child { border-bottom: none; }
  .nav-dropdown a:hover {
    color: var(--gold) !important;
    background: rgba(255,255,255,0.03);
  }

  /* MOBILE TOGGLE */
  .nav-mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-mobile-toggle span {
    display: block;
    width: 28px;
    height: 2px;
    background: var(--light);
    transition: all 0.3s;
  }

  /* MOBILE MENU */
  .nav-mobile-menu {
    display: none;
    background: var(--dark-2);
    border-top: 1px solid var(--gold-dim);
    padding: 1.5rem 2rem 2rem;
    max-height: calc(100vh - 90px);
    max-height: calc(100dvh - 90px);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .nav-mobile-menu.open { display: block; }
  .nav-mobile-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    margin-bottom: 2rem;
  }
  .nav-mobile-menu a {
    font-family: var(--font-cond);
    font-size: 1.25rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--light-dim);
    transition: color 0.2s;
  }
  .nav-mobile-menu a:hover { color: var(--gold); }
  .mobile-cta { color: var(--gold) !important; }
  .nav-mobile-menu .nav-faq { text-transform: none !important; }

  /* SERVICES ACCORDION TOGGLE */
  .mobile-section-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .mobile-section-label {
    font-family: var(--font-cond);
    font-size: 1.25rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--light-dim);
  }

  .mobile-chevron {
    color: var(--muted);
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .mobile-section-toggle[aria-expanded="true"] .mobile-chevron {
    transform: rotate(180deg);
  }

  .nav-mobile-menu .mobile-sub {
    list-style: none;
    display: none;
    flex-direction: column;
    gap: 0.75rem;
    padding-left: 1rem;
    margin-top: 0.75rem;
    margin-bottom: 0.5rem;
    border-left: 1px solid var(--gold-dim);
    overflow: hidden;
  }
  .nav-mobile-menu .mobile-sub.open {
    display: flex;
  }
  .mobile-sub li { line-height: 1; }
  .mobile-sub a {
    font-size: 0.95rem !important;
    color: var(--muted) !important;
    letter-spacing: 0.08em !important;
  }
  .mobile-sub a:hover { color: var(--gold) !important; }

  .mobile-socials {
    display: flex;
    gap: 1.2rem;
    color: var(--muted);
  }
  .mobile-socials a {
    color: var(--muted);
    transition: color 0.2s;
    font-size: 0 !important;
    letter-spacing: 0 !important;
    text-transform: none !important;
  }
  .mobile-socials a:hover { color: var(--gold); }

  @media (max-width: 768px) {
    .nav-links-desktop { display: none; }
    .nav-mobile-toggle { display: flex; }
    .nav-logo-text { font-size: 1.45rem; }
    .nav-logo-img { width: 48px; height: 48px; }
    .nav-inner { height: 90px; }
  }

  /* FOOTER */
  footer {
    background: var(--dark-2);
    border-top: 1px solid var(--gold-dim);
    padding: 5rem 0 2rem;
    margin-top: 0;
    position: relative;
    overflow: hidden;
  }

  footer::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/images/map-bg.webp');
    background-size: cover;
    background-position: center top;
    opacity: 0.08;
    filter: grayscale(100%) sepia(30%);
    pointer-events: none;
    z-index: 0;
  }

  footer .container {
    position: relative;
    z-index: 1;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .footer-logo-img {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .footer-logo span {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.06em;
    color: var(--light);
    line-height: 1.2;
  }

  .footer-logo span em {
    font-style: normal;
    color: var(--gold);
  }

  .footer-brand p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 280px;
  }

  .footer-socials {
    display: flex;
    gap: 1rem;
  }
  .footer-socials a {
    color: var(--muted);
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }
  .footer-socials a:hover { color: var(--gold); }

  .footer-col h4 {
    font-family: var(--font-cond);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.2rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-col ul li,
  .footer-col ul a {
    color: var(--muted);
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .footer-col ul a:hover { color: var(--light); }

  .footer-bottom {
