---
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    id: 1,
    tag: "Resource",
    title: "Flooring Options",
    body: "This is my company of choice for flooring. Browse their full selection and find something you like. I'll handle the rest.",
    link: "http://www.tecsunflooring.com/",
    linkLabel: "Visit Tecsun Flooring →",
    bg: "/resources/1.png",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>`,
  },
  {
    id: 2,
    tag: "Resource",
    title: "Trim & Moulding",
    body: "For baseboards, door casing, and crown moulding Decorative Woods has a huge variety. Browse their catalog before we kick off your next project.",
    link: "https://decorativewoods.com/",
    linkLabel: "Browse Decorative Woods →",
    bg: "/resources/2.png",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    id: 3,
    tag: "Note",
    title: "Don't See Your Service?",
    body: "Just ask. If I'm not your guy, I know the guy. No project is too obscure, reach out and I'll point you in the right direction.",
    link: "/contact",
    linkLabel: "Get in Touch →",
    bg: "/resources/3.png",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
  },
  {
    id: 4,
    tag: "Community",
    title: "Find Me on Nextdoor",
    body: "I'm active in the local Nextdoor community. Look me up, read reviews from your neighbors, and reach out directly through the platform.",
    link: "https://nextdoor.com/page/c-handy-solutions-pollock-id",
    linkLabel: "Find on Nextdoor →",
    bg: "/resources/4.png",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    id: 5,
    tag: "Client's Corner",
    title: "Leave Us a Review",
    body: "Your feedback means the world. If you've worked with us and had a great experience, take a moment to leave a Google review. It helps other homeowners find quality work they can trust.",
    link: "https://g.page/r/Cfdi4TP7ySehEBM/review",
    linkLabel: "Write a Review →",
    bg: "/resources/5.png",
    bgStyle: "background-size: contain; background-repeat: no-repeat; background-position: center 60%;",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  },
];
---

<Layout title="Client's Corner">

  <!-- PAGE HEADER -->
  <section class="page-header" style="background-image: url('/resources/6.png');">
    <div class="page-header-overlay"></div>
    <div class="container page-header-content">
      <span class="section-eyebrow fade-up delay-1">Updates & Resources</span>
      <h1 class="fade-up delay-2">Client's<br /><span class="gold">Corner</span></h1>
      <p class="fade-up delay-3">Notes, recommendations, and resources from Clark, things worth knowing before your next project.</p>
    </div>
    <div class="header-rule"></div>
  </section>

  <!-- BOARD -->
  <section class="board-section">
    <div class="container">
      <div class="board-grid">
        {posts.map((post, i) => (
          <article class={`board-card fade-up delay-${i + 1}`} style={`background-image: url('${post.bg}'); ${post.bgStyle || ''}`}>
            <div class="card-overlay"></div>
            <div class="card-content">
              <div class="card-top">
                <div class="card-icon" set:html={post.icon} />
                <span class="card-tag">{post.tag}</span>
              </div>
              <h2 class="card-title">{post.title}</h2>
              <p class="card-body">{post.body}</p>
              <a href={post.link} class="card-link" target={post.link.startsWith('http') ? '_blank' : '_self'} rel="noopener">
                {post.linkLabel}
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ─── PAGE HEADER ─── */
  .page-header {
    position: relative;
    padding-top: calc(var(--nav-h) + 6rem);
    padding-bottom: 5rem;
    overflow: hidden;
    background-size: cover;
    background-position: center;
  }

  .page-header-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    z-index: 0;
  }

  .page-header-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .page-header-content .section-eyebrow {
    text-align: center;
    font-size: 0.85rem;
    letter-spacing: 0.22em;
  }

  .page-header-content h1 {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7vw, 4.2rem);
    line-height: 0.92;
    letter-spacing: 0.02em;
    color: var(--light);
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .page-header-content h1 .gold {
    color: var(--gold);
  }

  .page-header-content p {
    color: var(--muted);
    font-size: 1.15rem;
    line-height: 1.7;
    max-width: 500px;
    text-align: center;
  }

  .header-rule {
    position: relative;
    z-index: 1;
    margin-top: 4rem;
    height: 1px;
    background: rgba(255,255,255,0.07);
  }

  /* ─── BOARD SECTION ─── */
  .board-section {
    padding: 7rem 0;
  }

  .board-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ─── CARD ─── */
  .board-card {
    position: relative;
    background-size: cover;
    background-position: center;
    border: 1px solid rgba(255,255,255,0.06);
    border-top: 2px solid var(--gold-dim);
    padding: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: border-color 0.25s, transform 0.25s;
    min-height: 320px;
  }

  .board-card:hover {
    border-top-color: var(--gold);
    transform: translateY(-3px);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    transition: background 0.3s;
  }

  .board-card:hover .card-overlay {
    background: rgba(0, 0, 0, 0.6);
  }

  .card-content {
    position: relative;
    z-index: 1;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.4rem;
  }

  .card-icon {
    color: var(--gold);
    opacity: 0.85;
    display: flex;
    align-items: center;
  }

  .card-tag {
    font-family: var(--font-cond);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    letter-spacing: 0.03em;
    line-height: 1;
    color: var(--light);
    margin-bottom: 0.9rem;
  }

  .card-body {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.75;
    flex: 1;
    margin-bottom: 1.5rem;
  }

  .card-link {
    font-family: var(--font-cond);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    transition: opacity 0.2s;
    align-self: flex-start;
    margin-top: auto;
  }

  .card-link:hover {
    opacity: 0.7;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .board-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .board-grid {
      grid-template-columns: 1fr;
    }
  }
</style>