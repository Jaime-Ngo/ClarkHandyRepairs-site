  padding: 1rem 0;
  position: sticky; top: var(--nav-h); z-index: 50;
}
.filter-inner {
  display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;
  -webkit-overflow-scrolling: touch;
}
.filter-btn {
  background: transparent;
  border: 1px solid transparent;
  color: var(--muted);
  font-family: var(--font-cond);
  font-size: 0.78rem; letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.4rem 1rem; border-radius: 2px;
  cursor: pointer; transition: all 0.2s;
  white-space: nowrap;
}
.filter-btn:hover { color: var(--light); border-color: rgba(255,255,255,0.15); }
.filter-btn.active {
  color: var(--gold); border-color: var(--gold-dim);
  background: rgba(201,168,76,0.06);
}

/* PROJECT GRID */
.portfolio-section { padding: 4rem 0 6rem; }
.project-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.project-card {
  cursor: pointer;
  border-radius: 3px;
  overflow: hidden;
  background: var(--dark-2);
  border: 1px solid rgba(255,255,255,0.04);
  transition: transform 0.35s cubic-bezier(.22,1,.36,1), box-shadow 0.35s ease;
  animation: cardIn 0.5s ease both;
}
@keyframes cardIn {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}
.project-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(0,0,0,0.4);
}
.card-thumb {
  position: relative;
  height: 300px;
  overflow: hidden;
}
.card-img {
  width: 100%; height: 100%;
  background-size: cover; background-position: center;
  transition: transform 0.5s cubic-bezier(.22,1,.36,1);
}
.project-card:hover .card-img { transform: scale(1.05); }

/* ── CARD OVERLAY — gradient with title, darkens on hover ── */
.project-card .card-overlay {
  position: absolute !important; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0) 50%) !important;
  display: flex !important;
  align-items: flex-end !important;
  justify-content: flex-start !important;
  padding: 1.5rem !important;
  transition: background 0.35s ease;
  z-index: 2;
}
.project-card .card-text {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.project-card .card-title {
  font-family: var(--font-display);
  font-weight: 400 !important;
  font-size: 1.4rem !important; line-height: 1.1 !important;
  color: var(--light) !important;
  letter-spacing: 0.04em !important;
  text-transform: uppercase !important;
  margin: 0 !important;
  text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  opacity: 1 !important;
  transition: transform 0.3s ease;
}
.project-card .card-desc {
  font-size: 0.82rem !important;
  color: var(--muted) !important;
  line-height: 1.45 !important;
  margin: 0 !important;
  max-height: 0 !important;
  opacity: 0 !important;
  overflow: hidden !important;
  transition: max-height 0.35s ease, opacity 0.3s ease 0.05s, margin 0.35s ease;
}

/* Desktop: .hovered class reveals subtitle */
.project-card.hovered .card-overlay,
.project-card.revealed .card-overlay { background: rgba(0,0,0,0.65) !important; }
.project-card.hovered .card-desc,
.project-card.revealed .card-desc {
  max-height: 60px !important;
  opacity: 1 !important;
  margin-top: 0.5rem !important;
}

.project-card.hidden { display: none; }

@media (max-width: 960px) {
  .project-grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
}
@media (max-width: 560px) {
  .project-grid { grid-template-columns: 1fr; gap: 1rem; }
  .card-thumb { height: 240px; }
}

/* LIGHTBOX */
.lightbox {
  position: fixed; inset: 0; z-index: 9999;
  display: flex; align-items: flex-start; justify-content: center;
  overflow-y: auto;
  pointer-events: none; opacity: 0;
  transition: opacity 0.3s ease;
}
.lightbox.open { pointer-events: all; opacity: 1; }
.lb-backdrop {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.92);
  backdrop-filter: blur(8px);
}
.lb-container {
  position: relative; z-index: 2;
  width: 100%; max-width: 900px;
  padding: 2rem 1.5rem 4rem;
  transform: translateY(20px);
  transition: transform 0.35s cubic-bezier(.22,1,.36,1);
}
.lightbox.open .lb-container { transform: translateY(0); }
.lb-close {
  position: fixed; top: 1.25rem; right: 1.5rem;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 50%; width: 44px; height: 44px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; z-index: 10;
  transition: all 0.2s;
}
.lb-close svg { width: 18px; height: 18px; color: var(--light); }
.lb-close:hover { background: rgba(255,255,255,0.12); border-color: var(--gold-dim); }
.lb-header { margin-bottom: 2rem; text-align: center; }
.lb-title {
  font-family: var(--font-display);
  font-weight: 400 !important;
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  color: var(--muted) !important; line-height: 1.1;
  margin-bottom: 0.5rem;
  text-transform: none !important;
}
.lb-subtitle { color: var(--gold) !important; font-size: 0.92rem; margin-bottom: 1rem; }
.lb-scope { display: none; }

/* Gallery */
.lb-gallery {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}
.lb-gallery-img {
  width: 100%; border-radius: 2px;
  cursor: pointer;
  transition: opacity 0.2s;
  border: 1px solid rgba(255,255,255,0.04);
}
.lb-gallery-img.img-ph { aspect-ratio: 4 / 3; }
.lb-gallery-img:hover { opacity: 0.85; }
.lb-gallery-img.wide { grid-column: 1 / -1; }

.card-tag {
  font-family: var(--font-cond);
  font-size: 0.62rem; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--gold);
  border: 1px solid var(--gold-dim);
  padding: 0.18rem 0.55rem; border-radius: 1px;
}

.lb-counter {
  text-align: center; margin-top: 1.5rem;
  font-family: var(--font-cond);
  font-size: 0.7rem; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--muted);
}

@media (max-width: 560px) {
  .lb-gallery { grid-template-columns: 1fr; }
  .lb-container { padding: 1.5rem 1rem 3rem; }
}

/* CTA */
.portfolio-cta {
  padding: 7rem 0;
  background: var(--dark-2);
  border-top: 1px solid var(--gold-dim);
}
</style>

<script define:vars={{ projects }}>
const projectData = projects;
const lb = document.getElementById('lightbox');
const lbTitle = document.getElementById('lbTitle');
const lbSubtitle = document.getElementById('lbSubtitle');
const lbScope = document.getElementById('lbScope');
const lbGallery = document.getElementById('lbGallery');
const lbCounter = document.getElementById('lbCounter');

/* Detect touch device */
const isTouchDevice = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);

/* FILTER */
const filterBtns = document.querySelectorAll('.filter-btn');
const cards = document.querySelectorAll('.project-card');
filterBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    filterBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const cat = btn.dataset.cat;
    cards.forEach(card => {
      if (cat === 'All' || card.dataset.cat.split(',').includes(cat)) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
  });
});

/* CARD CLICK LOGIC
   Desktop (hover devices): hover shows description, click opens lightbox
   Mobile (touch devices): 1st tap shows description, 2nd tap opens lightbox */
cards.forEach(card => {
  /* Desktop hover — add/remove .hovered class via JS */
  card.addEventListener('mouseenter', () => {
    if (!isTouchDevice) card.classList.add('hovered');
  });
  card.addEventListener('mouseleave', () => {
    card.classList.remove('hovered');
  });

  card.addEventListener('click', (e) => {
    const idx = parseInt(card.dataset.idx);

    if (isTouchDevice) {
      // If card is NOT yet revealed, reveal it (first tap)
      if (!card.classList.contains('revealed')) {
        // Close any other revealed cards first
        cards.forEach(c => c.classList.remove('revealed'));
        card.classList.add('revealed');
        e.preventDefault();
        return;
      }
      // If already revealed, open lightbox (second tap)
      openLightbox(idx);
    } else {
      // Desktop: click always opens lightbox (hover already shows description)
      openLightbox(idx);
    }
  });
});

/* Close revealed cards when tapping outside on mobile */
if (isTouchDevice) {
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.project-card')) {
      cards.forEach(c => c.classList.remove('revealed'));
    }
  });
}

/* OPEN LIGHTBOX */
function openLightbox(idx) {
  const p = projectData[idx];
  lbTitle.textContent = p.title;
  lbSubtitle.textContent = p.subtitle;
  lbScope.innerHTML = p.scope.map(s =>
    `<span class="card-tag">${s}</span>`
  ).join('');
  renderGallery(p);
  lb.classList.add('open');
  lb.setAttribute('aria-hidden', 'false');
  document.body.style.overflow = 'hidden';
}

function renderGallery(p) {
  const imgs = p.images;
  lbGallery.innerHTML = imgs.map((img, i) => {
    const isWide = imgs.length === 1 || (imgs.length === 3 && i === 0);
    return `
      <div style="position:relative;" class="${isWide ? 'wide' : ''}">
        <div class="lb-gallery-img${isWide ? ' wide' : ''}"
             data-label="${img.alt}"
             style="background-image:url('${img.src}');background-size:cover;background-position:center;aspect-ratio:${isWide ? '16/10' : '4/3'};">
        </div>
      </div>
    `;
  }).join('');
  lbCounter.textContent = `${imgs.length} photo${imgs.length !== 1 ? 's' : ''}`;
}

/* CLOSE LIGHTBOX */
function closeLightbox() {
  lb.classList.remove('open');
  lb.setAttribute('aria-hidden', 'true');
  document.body.style.overflow = '';
}
document.querySelector('.lb-close').addEventListener('click', closeLightbox);
document.querySelector('.lb-backdrop').addEventListener('click', closeLightbox);
document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && lb.classList.contains('open')) closeLightbox();
});
</script>