---
<Layout title="Portfolio">

<!-- PAGE HERO -->
<section class="page-hero">
  <video class="page-hero-video" autoplay muted loop playsinline>
    <source src="/portfolio/hero-reel.mp4" type="video/mp4" />
  </video>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <span class="section-eyebrow hero-eyebrow fade-up delay-1">Our Work</span>
    <h1 class="hero-heading fade-up delay-2">Portfolio</h1>
    <p class="fade-up delay-3">Real jobs. Real results. Browse our completed projects and see the quality we bring to every home.</p>
  </div>
</section>

<!-- FILTER BAR -->
<div class="filter-bar">
  <div class="container filter-inner">
    {usedCategories.map(cat => (
      <button class={`filter-btn ${cat === 'All' ? 'active' : ''}`} data-cat={cat}>{cat}</button>
    ))}
  </div>
</div>

<!-- PROJECT GRID -->
<section class="portfolio-section">
  <div class="container">
    <div class="project-grid" id="projectGrid">
      {projects.map((project, idx) => (
        <article
          class="project-card"
          data-cat={Array.isArray(project.category) ? project.category.join(',') : project.category}
          data-idx={idx}
          style={`animation-delay: ${idx * 0.06}s`}
        >
          <div class="card-thumb">
            <div class="card-img" style={`background-image:url('${project.thumbnail}')`}></div>
            <div class="card-overlay">
              <div class="card-text">
                <h3 class="card-title">{project.title}</h3>
                <p class="card-desc">{project.subtitle}</p>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox" aria-hidden="true">
  <div class="lb-backdrop"></div>
  <div class="lb-container">
    <button class="lb-close" aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="4" x2="20" y2="20"/><line x1="20" y1="4" x2="4" y2="20"/></svg>
    </button>
    <div class="lb-header">
      <h2 class="lb-title" id="lbTitle"></h2>
      <p class="lb-subtitle" id="lbSubtitle"></p>
      <div class="lb-scope" id="lbScope"></div>
    </div>
    <div class="lb-gallery" id="lbGallery"></div>
    <div class="lb-counter" id="lbCounter"></div>
  </div>
</div>

<!-- CTA -->
<section class="portfolio-cta">
  <div class="container" style="text-align:center;">
    <span class="section-eyebrow">Like What You See?</span>
    <div class="gold-line" style="margin: 0 auto 1.5rem;"></div>
    <h2 class="section-title">Let's Add Your Project<br /><span style="color:var(--gold);">to This Wall</span></h2>
    <p class="section-body" style="margin: 0 auto 2.5rem; max-width:440px; text-align:center;">Every great result starts with a conversation. Reach out and tell us what you need.</p>
    <a href="/contact" class="btn btn-gold">Get a Free Quote</a>
  </div>
</section>

</Layout>

<style>
/* PAGE HERO */
.page-hero {
  position: relative;
  height: 85vh;
  min-height: 580px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}
