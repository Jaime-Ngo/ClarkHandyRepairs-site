---
import Layout from '../layouts/Layout.astro';

const categories = ['All', 'Plumbing', 'Electrical', 'Painting', 'Flooring', 'Drywall', 'Doors', 'Smart Home'];

// Portfolio items - replace src with real images when available
const items = Array.from({ length: 18 }, (_, i) => ({
  id: i + 1,
  label: `Portfolio Photo ${i + 1}`,
  category: categories[(i % (categories.length - 1)) + 1],
}));
---

<Layout title="Portfolio">

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="page-hero-bg img-ph" data-label="Portfolio Hero Image"></div>
    <div class="page-hero-overlay"></div>
    <div class="container page-hero-content">
      <span class="section-eyebrow fade-up delay-1">Our Work</span>
      <h1 class="fade-up delay-2">Portfolio</h1>
      <p class="fade-up delay-3">Real jobs. Real results. Browse our completed projects and see the quality we bring to every home.</p>
    </div>
  </section>

  <!-- FILTER BAR -->
  <div class="filter-bar">
    <div class="container filter-inner">
      {categories.map(cat => (
        <button class={`filter-btn ${cat === 'All' ? 'active' : ''}`} data-cat={cat}>{cat}</button>
      ))}
    </div>
  </div>

  <!-- PHOTO GRID -->
  <section class="portfolio-section">
    <div class="container">
      <div class="portfolio-masonry" id="portfolioGrid">
        {items.map(item => (
          <div class="portfolio-item img-ph" data-label={item.label} data-cat={item.category}>
            <div class="portfolio-hover">
              <span>{item.category}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="portfolio-cta">
    <div class="container" style="text-align:center;">
      <span class="section-eyebrow">Like What You See?</span>
      <div class="gold-line" style="margin: 0 auto 1.5rem;"></div>
      <h2 class="section-title">Let's Add Your Project<br />to This Wall</h2>
      <p class="section-body" style="margin: 0 auto 2.5rem; max-width:440px; text-align:center;">Every great result starts with a conversation. Reach out and tell us what you need.</p>
      <a href="/contact" class="btn btn-gold">Get a Free Quote</a>
    </div>
  </section>

</Layout>

<style>
  /* PAGE HERO */
  .page-hero {
    position: relative;
    height: 52vh;
    min-height: 380px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.45) 100%);
    z-index: 1;
  }
  .page-hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: 4rem;
    padding-top: var(--nav-h);
  }
  .page-hero-content h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    color: var(--light);
    margin-bottom: 1rem;
  }
  .page-hero-content p {
    color: var(--light-dim);
    font-size: 1rem;
    max-width: 480px;
  }

  /* FILTER BAR */
  .filter-bar {
    background: var(--dark-2);
    border-bottom: 1px solid var(--gold-dim);
    padding: 1rem 0;
    position: sticky;
    top: var(--nav-h);
    z-index: 50;
  }

  .filter-inner {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .filter-btn {
    background: transparent;
    border: 1px solid transparent;
    color: var(--muted);
    font-family: var(--font-cond);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .filter-btn:hover {
    color: var(--light);
    border-color: rgba(255,255,255,0.15);
  }
  .filter-btn.active {
    color: var(--gold);
    border-color: var(--gold-dim);
    background: rgba(201,168,76,0.06);
  }

  /* PORTFOLIO GRID */
  .portfolio-section {
    padding: 4rem 0 6rem;
  }

  .portfolio-masonry {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .portfolio-item {
    height: 280px;
    border-radius: 1px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  .portfolio-item:nth-child(5n + 1) { height: 360px; }
  .portfolio-item:nth-child(7n + 3) { height: 320px; }

  .portfolio-hover {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0);
    display: flex;
    align-items: flex-end;
    padding: 1.2rem;
    transition: background 0.3s;
    z-index: 2;
  }

  .portfolio-item:hover .portfolio-hover {
    background: rgba(0,0,0,0.55);
  }

  .portfolio-hover span {
    font-family: var(--font-cond);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.3s;
  }

  .portfolio-item:hover .portfolio-hover span {
    opacity: 1;
    transform: translateY(0);
  }

  .portfolio-item.hidden { display: none; }

  @media (max-width: 768px) {
    .portfolio-masonry { grid-template-columns: repeat(2, 1fr); }
    .portfolio-item { height: 200px !important; }
  }
  @media (max-width: 480px) {
    .portfolio-masonry { grid-template-columns: 1fr; }
    .portfolio-item { height: 240px !important; }
  }

  /* CTA */
  .portfolio-cta {
    padding: 7rem 0;
    background: var(--dark-2);
    border-top: 1px solid var(--gold-dim);
  }
</style>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.portfolio-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = btn.dataset.cat;
      items.forEach(item => {
        if (cat === 'All' || item.dataset.cat === cat) {
          item.classList.remove('hidden');
        } else {
          item.classList.add('hidden');
        }
      });
    });
  });
</script>