---
import Layout from '../layouts/Layout.astro';

// Add real images here — replace src paths with actual portfolio photos from Oscar
// Recommended: place images in /public/portfolio/ and reference as /portfolio/photo1.jpg etc.
const photos = [
  { src: '/portfolio/photo1.jpg', alt: 'Flooring installation project', category: 'Flooring' },
  { src: '/portfolio/photo2.jpg', alt: 'Interior painting', category: 'Painting' },
  { src: '/portfolio/photo3.jpg', alt: 'Drywall repair and finish', category: 'Drywall' },
  { src: '/portfolio/photo4.jpg', alt: 'Door installation', category: 'Doors' },
  { src: '/portfolio/photo5.jpg', alt: 'Plumbing repair', category: 'Plumbing' },
  { src: '/portfolio/photo6.jpg', alt: 'Interior trim work', category: 'Trim' },
  { src: '/portfolio/photo7.jpg', alt: 'Junk removal & hauling', category: 'Junk Removal' },
  { src: '/portfolio/photo8.jpg', alt: 'Electrical work', category: 'Electrical' },
  { src: '/portfolio/photo9.jpg', alt: 'Flooring project complete', category: 'Flooring' },
  { src: '/portfolio/photo10.jpg', alt: 'Painting project finished', category: 'Painting' },
  { src: '/portfolio/photo11.jpg', alt: 'Bathroom renovation', category: 'Renovation' },
  { src: '/portfolio/photo12.jpg', alt: 'Trim and baseboard install', category: 'Trim' },
];

const categories = ['All', ...new Set(photos.map(p => p.category))];
---
<Layout title="Portfolio — Clark Handy Solutions">

  <!-- Page Hero -->
  <section class="relative pt-36 pb-20 bg-[#1E1208] grain overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_50%_80%,rgba(196,106,31,0.12),transparent)]"></div>
    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <p class="text-xs tracking-[0.3em] uppercase text-[#C46A1F] font-semibold mb-3">Our Work</p>
      <h1 class="font-['Playfair_Display'] font-black text-5xl md:text-6xl text-[#FAF7F2] mb-5">The Portfolio</h1>
      <p class="text-white/60 text-lg max-w-2xl mx-auto">Every project tells a story. Here's a look at the work we're proud of — all done right here in Orange County.</p>
    </div>
  </section>

  <!-- Filter Tabs -->
  <section class="py-8 bg-[#F5F0E8] border-b border-[#EDE5D4] sticky top-16 z-30">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-wrap gap-2 justify-center" id="filter-tabs">
        {categories.map((cat, i) => (
          <button
            class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 border"
            data-category={cat}
            data-active={i === 0 ? 'true' : 'false'}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="py-16 bg-[#F5F0E8]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4" id="gallery">
        {photos.map((photo) => (
          <div
            class="gallery-item break-inside-avoid rounded-xl overflow-hidden cursor-pointer group relative"
            data-category={photo.category}
          >
            <img
              src={photo.src}
              alt={photo.alt}
              class="w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-linear-to-trom-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
              <div>
                <span class="text-xs font-semibold text-[#C46A1F] tracking-widest uppercase">{photo.category}</span>
                <p class="text-white text-sm">{photo.alt}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Instagram CTA -->
      <div class="text-center mt-16 pt-16 border-t border-[#EDE5D4]">
        <p class="text-[#7A6652] mb-4 text-sm">Follow us on Instagram for more recent work</p>
        <a
          href="https://www.instagram.com/chandysolutions/"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 bg-linear-to-r from-[#C46A1F] to-[#E08030] text-white font-semibold px-8 py-4 rounded-full hover:shadow-xl hover:shadow-amber-900/30 hover:-translate-y-0.5 transition-all duration-200"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          @chandysolutions
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .filter-btn[data-active="true"] {
    background-color: #C46A1F;
    color: white;
    border-color: #C46A1F;
  }
  .filter-btn[data-active="false"] {
    background-color: transparent;
    color: #3B2310;
    border-color: #EDE5D4;
  }
  .filter-btn[data-active="false"]:hover {
    border-color: #C46A1F;
    color: #C46A1F;
  }
</style>

<script>
  const tabs = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.gallery-item');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const cat = tab.getAttribute('data-category');

      // Update active state
      tabs.forEach(t => t.setAttribute('data-active', 'false'));
      tab.setAttribute('data-active', 'true');

      // Filter items
      items.forEach(item => {
        const itemCat = item.getAttribute('data-category');
        if (cat === 'All' || itemCat === cat) {
          (item as HTMLElement).style.display = 'block';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>