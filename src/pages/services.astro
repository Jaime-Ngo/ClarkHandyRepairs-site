      'Dresser and Wardrobe Assembly',
    ],
  },
  {
    id: 'smarthome',
    category: 'Smart Home & Tech',
    tagline: ['Modern Living,', 'Expertly Installed'],
    description: 'We install and set up smart home devices so everything works right from day one — no frustration, no loose wires.',
    items: [
      'TV Mounting',
      'TV Mounting with Wire Concealment',
