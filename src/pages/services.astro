  {
    id: 'plumbing-bathroom',
    category: 'Bathroom',
    tagline: ['Reliable Fixes,', 'No Surprises'],
    description: 'From toilet installations to full bathtub replacements, we handle all your bathroom plumbing with care and precision. No mess left behind.',
    items: [
      'Faucet Replacement',
      'Toilet Installation',
      'Bathroom Sink Installation',
      'Drain Clog Service',
      'Shower Valve Installation & Cartridge Replacement',
      'Shower Door Installation',
      'Bathtub Installation',
      'Angle Stop (Water Supply Valve) Replacement',
      'Plumbing Fixture Installation',
    ],
  },
  {
    id: 'electrical',
