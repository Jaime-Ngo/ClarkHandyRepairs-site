  {
    id: 'hvac',
    category: 'HVAC',
    tagline: ['Comfort You Can', 'Count On'],
    description: 'From thermostat upgrades to register replacements and filter swaps, we keep your heating and cooling running smoothly all year round.',
    items: [
      'Thermostat Installation and Replacement',
      'Smart Thermostat Setup',
