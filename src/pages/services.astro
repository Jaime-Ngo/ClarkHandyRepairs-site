  {
    id: 'doors',
    category: 'Doors & Hardware',
    tagline: ['Smooth Operation,', 'Every Time'],
    description: 'From hanging a new door to installing smart locks and adjusting stubborn cabinet hinges, we sweat the details so you don\'t have to.',
