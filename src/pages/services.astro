---
<Layout title="Services — Clark Handy Solutions">

  <!-- Page Hero -->
  <section class="relative pt-36 pb-20 bg-[#1E1208] grain overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_50%_80%,rgba(196,106,31,0.12),transparent)]"></div>
    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <p class="text-xs tracking-[0.3em] uppercase text-[#C46A1F] font-semibold mb-3">What We Offer</p>
      <h1 class="font-['Playfair_Display'] font-black text-5xl md:text-6xl text-[#FAF7F2] mb-5">Our Services</h1>
      <p class="text-white/60 text-lg max-w-2xl mx-auto">From quick fixes to full renovations, Clark Handy Solutions handles it all. Every job treated with the same care and craftsmanship.</p>
    </div>
  </section>

  <!-- Services -->
  <section class="py-24 bg-[#F5F0E8]">
    <div class="max-w-7xl mx-auto px-6 space-y-16">
      {serviceCategories.map((cat, i) => (
        <div class="section-fade" style={`transition-delay: ${i * 40}ms`}>
          <!-- Category Header -->
          <div class="flex items-center gap-4 mb-6">
            <div class="flex-shrink-0 bg-[#1E1208] text-[#C46A1F] rounded-xl p-3" set:html={cat.icon}></div>
            <div>
              <h2 class="font-['Playfair_Display'] text-2xl font-bold text-[#1E1208]">{cat.name}</h2>
              <p class="text-[#7A6652] text-sm">{cat.description}</p>
            </div>
          </div>

          <!-- Service Items -->
          <div class="grid md:grid-cols-2 gap-3 ml-0 md:ml-16">
            {cat.items.map(item => (
              <div class="bg-white border border-[#EDE5D4] rounded-xl p-5 hover:border-[#C46A1F]/40 hover:shadow-md transition-all duration-200 group">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1">
                    <h3 class="font-semibold text-[#1E1208] text-sm mb-1 group-hover:text-[#C46A1F] transition-colors">{item.name}</h3>
                    {item.note && <p class="text-[#7A6652] text-xs leading-relaxed">{item.note}</p>}
                  </div>
                  <div class="text-right flex-shrink-0">
                    <div class="text-[#C46A1F] font-semibold text-sm">{item.price}</div>
                    {item.duration && <div class="text-[#7A6652] text-xs">{item.duration}</div>}
                  </div>
                </div>
                <a
                  href="https://book.squareup.com/appointments/khle4gl514w5yy/location/LM8HDZG27SBX4/services"
                  target="_blank"
                  rel="noopener"
                  class="inline-block mt-3 text-xs font-semibold text-[#C46A1F] hover:underline"
                >
                  Book now →
                </a>
              </div>
            ))}
          </div>

          <!-- Divider -->
          {i < serviceCategories.length - 1 && (
            <div class="mt-12 border-b border-[#EDE5D4]"></div>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-[#C46A1F]">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-['Playfair_Display'] text-4xl font-black text-white mb-4">Don't See What You Need?</h2>
      <p class="text-white/80 mb-8">We handle a wide range of home repair and custom projects. Get in touch and we'll work something out.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-[#C46A1F] font-bold px-8 py-4 rounded-full hover:bg-[#FAF7F2] transition-colors">
          Contact Us
        </a>
        <a
          href="https://book.squareup.com/appointments/khle4gl514w5yy/location/LM8HDZG27SBX4/services"
          target="_blank"
          class="border-2 border-white text-white font-bold px-8 py-4 rounded-full hover:bg-white/10 transition-colors"
        >
          Book Online
        </a>
      </div>
    </div>
  </section>

</Layout>