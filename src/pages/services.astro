---

<Layout title="Services">

  <!-- PAGE HERO -->
  <section class="page-hero">
    <img class="page-hero-bg" src="/images/services-hero.webp" alt="Clark Handy Solutions services" />
    <div class="page-hero-overlay"></div>
    <div class="container page-hero-content">
      <span class="section-eyebrow fade-up delay-1">What We Offer</span>
      <h1 class="fade-up delay-2">Our <span class="gold-text">Services</span></h1>
      <p class="fade-up delay-3">Professional handyman work across every corner of your home. Explore what we do and reach out for a free estimate.</p>
    </div>
  </section>

  <!-- SERVICES LIST -->
  {services.map((service, i) => (
    <section id={service.id} class={`service-section ${i % 2 === 0 ? 'even' : 'odd'}`}>
      <div class="service-inner">
        <div class="service-img-col">
          <img class="service-img" src={`/images/service-${service.id}.webp`} alt={`${service.category} services`} />
        </div>
        <div class="service-text-col">
          <span class="section-eyebrow">{service.category}</span>
          <div class="gold-line"></div>
          <h2 class="section-title">
            {service.tagline[0]}<br /><span class="gold-text">{service.tagline[1]}</span>
          </h2>
          <p class="section-body">{service.description}</p>
          <ul class="service-list">
            {service.items.map(item => (
              <li><span class="bullet">—</span>{item}</li>
            ))}
          </ul>
          <a href="/contact" class="btn btn-gold" style="margin-top: 2rem; display: inline-block;">Get a Quote</a>
        </div>
      </div>
    </section>
  ))}

  <!-- ADDITIONAL / MISC CTA -->
  <section class="services-cta">
    <img class="services-cta-bg" src="/images/services-cta-bg.webp" alt="" />
    <div class="services-cta-overlay"></div>
    <div class="container services-cta-content">
      <span class="section-eyebrow">Don't See Your Job Listed?</span>
      <h2 class="section-title">We Probably <span class="gold-text">Do It.</span></h2>
      <p class="section-body">Our services go far beyond what's listed here. Reach out and describe what you need — chances are we can help.</p>
      <div style="display:flex; gap:1rem; flex-wrap:wrap; margin-top:2rem;">
        <a href="/contact" class="btn btn-gold">Contact Us</a>
        <a href="tel:9497340972" class="btn btn-outline">(949) 734-0972</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .gold-text {
    color: var(--gold);
  }

  /* PAGE HERO */
  .page-hero {
    position: relative;
    height: 52vh;
    min-height: 380px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.45) 100%);
    z-index: 1;
  }

  .page-hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: 4rem;
    padding-top: var(--nav-h);
  }

  .page-hero-content h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    color: var(--light);
    margin-bottom: 1rem;
  }

  .page-hero-content p {
    color: var(--light-dim);
    font-size: 1rem;
    max-width: 480px;
  }

  /* SERVICE SECTIONS */
  .service-section {
    padding: 0 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }

  .service-section.odd { background: var(--dark-2); }
  .service-section.even { background: var(--dark); }

  .service-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
    max-width: 1400px;
    margin: 0 auto;
    gap: 4rem;
  }

  .odd .service-inner {
    direction: rtl;
  }
  .odd .service-text-col,
  .odd .service-img-col {
    direction: ltr;
  }

  .service-img-col {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    margin: 3rem 0;
  }

  .service-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .service-text-col {
    padding: 5rem 0 5rem 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .service-list {
    list-style: none;
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .service-list li {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--light-dim);
    line-height: 1.5;
  }

  .bullet {
    color: var(--gold);
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  @media (max-width: 1100px) {
    .service-section {
      padding: 0 2rem;
    }

    .service-inner {
      gap: 2.5rem;
    }
  }

  @media (max-width: 900px) {
    .service-section {
      padding: 0 1.25rem;
    }

    .service-inner {
      grid-template-columns: 1fr;
      direction: ltr !important;
      gap: 0;
    }

    .odd .service-inner { direction: ltr; }

    .service-img-col {
      height: 260px;
      position: relative;
      margin: 1.5rem 0 0;
      border-radius: 8px 8px 0 0;
    }

    .service-img { position: absolute; inset: 0; }

    .service-text-col {
      padding: 2.5rem 0.5rem 3rem;
    }
  }

  /* SERVICES CTA */
  .services-cta {
    position: relative;
    padding: 8rem 0;
    overflow: hidden;
  }

  .services-cta-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .services-cta-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.6) 100%);
    z-index: 1;
  }

  .services-cta-content {
    position: relative;
    z-index: 2;
  }
</style>