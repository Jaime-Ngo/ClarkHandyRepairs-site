---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">

  <section class="about-section">
    <div class="container about-grid">
      <div class="about-image-wrap">
        <img class="about-img" src="/images/about-oscar.jpg" alt="Oscar Clark — Clark Handy Solutions" />
        <div class="about-img-accent"></div>
      </div>
      <div class="about-text">
        <span class="section-eyebrow">Meet Oscar</span>
        <div class="gold-line"></div>
        <h2 class="section-title">Your Neighborhood<br />Problem Solver</h2>
        <p class="section-body">Clark Handy Solutions prides itself on a work ethic designed to bring quality services into the homes of local neighborhoods. Flexible pricing is meant to communicate the desire for a business relationship rather than a series of financial transactions. Attention to detail is key because it's the little things that matter in the grand scheme of things. Every problem has a solution, and solutions lie in wait for those who are eager to figure them out. The importance of home is well understood, giving a greater meaning to the industry of service. I accept the challenge in making customer satisfaction more than a possibility.</p>
        <p class="section-body" style="margin-top: 1rem;">Based in Orange County and proudly serving the surrounding area, we bring professional-grade skills to jobs of every size.</p>
      </div>
    </div>
  </section>

</Layout>

<style>
  .about-section {
    padding: 10rem 0 7rem;
    background: var(--dark);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .about-image-wrap {
    position: relative;
    height: 520px;
  }

  .about-img {
    position: absolute;
    inset: 0;
    border-radius: 2px;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-img-accent {
    position: absolute;
    bottom: -16px;
    right: -16px;
    width: calc(100% - 32px);
    height: calc(100% - 32px);
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 2px;
    z-index: 0;
  }

  @media (max-width: 860px) {
    .about-grid { grid-template-columns: 1fr; }
    .about-image-wrap { height: 340px; }
  }
</style>