---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact — Clark Handy Solutions">

  <!-- Page Hero -->
  <section class="relative pt-36 pb-20 bg-[#1E1208] grain overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_50%_80%,rgba(196,106,31,0.12),transparent)]"></div>
    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <p class="text-xs tracking-[0.3em] uppercase text-[#C46A1F] font-semibold mb-3">Reach Out</p>
      <h1 class="font-['Playfair_Display'] font-black text-5xl md:text-6xl text-[#FAF7F2] mb-5">Let's Talk</h1>
      <p class="text-white/60 text-lg max-w-2xl mx-auto">Have a project in mind? Ready to book? We're easy to reach — just call, text, or use the form below.</p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-24 bg-[#F5F0E8]">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-5 gap-12">

      <!-- Left: Info -->
      <div class="md:col-span-2 section-fade">
        <h2 class="font-['Playfair_Display'] text-3xl font-bold text-[#1E1208] mb-8">Contact Info</h2>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-[#C46A1F]/10 rounded-xl flex items-center justify-center flex-shrink-0 text-lg">📞</div>
            <div>
              <p class="text-xs tracking-widest uppercase text-[#7A6652] mb-1">Phone / Text</p>
              <!-- Replace with Oscar's real number -->
              <a href="tel:+1XXXXXXXXXX" class="text-[#1E1208] font-semibold hover:text-[#C46A1F] transition-colors">(XXX) XXX-XXXX</a>
              <p class="text-xs text-[#7A6652] mt-0.5">Call or text anytime</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-[#C46A1F]/10 rounded-xl flex items-center justify-center flex-shrink-0 text-lg">📍</div>
            <div>
              <p class="text-xs tracking-widest uppercase text-[#7A6652] mb-1">Service Area</p>
              <p class="text-[#1E1208] font-semibold">Orange County, CA</p>
              <p class="text-xs text-[#7A6652] mt-0.5">Westminster, Huntington Beach & surrounding areas</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-[#C46A1F]/10 rounded-xl flex items-center justify-center flex-shrink-0 text-lg">🗓️</div>
            <div>
              <p class="text-xs tracking-widest uppercase text-[#7A6652] mb-1">Book Online</p>
              <a
                href="https://book.squareup.com/appointments/khle4gl514w5yy/location/LM8HDZG27SBX4/services"
                target="_blank"
                rel="noopener"
                class="text-[#C46A1F] font-semibold hover:underline"
              >
                Schedule via Square →
              </a>
            </div>
          </div>
        </div>

        <!-- Social Links -->
        <div class="mt-10 pt-8 border-t border-[#EDE5D4]">
          <p class="text-xs tracking-widest uppercase text-[#7A6652] mb-4">Follow Our Work</p>
          <div class="flex flex-col gap-3">
            <a href="https://www.instagram.com/chandysolutions/" target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-[#3B2310] hover:text-[#C46A1F] transition-colors font-medium">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              Instagram — @chandysolutions
            </a>
            <a href="https://www.facebook.com/CHandySolutionsOC/" target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-[#3B2310] hover:text-[#C46A1F] transition-colors font-medium">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook — Clark Handy Solutions
            </a>
            <a href="https://www.yelp.com/biz/clark-handy-solutions-westminster" target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-[#3B2310] hover:text-[#C46A1F] transition-colors font-medium">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.16 12.73l-4.703 1.14c-.103.025-.198.078-.275.152a.625.625 0 0 0-.056.77l2.91 3.956c.14.19.37.28.6.237.23-.044.413-.214.474-.44.47-1.733.558-3.556.234-5.332a.627.627 0 0 0-.563-.483h-.621zm-8.202 4.853l-1.49 4.537c-.073.22-.005.463.172.614.178.15.426.18.634.072 1.618-.85 3.01-2.088 4.037-3.594a.625.625 0 0 0-.109-.845l-3.244-1.022zm-4.47-1.985l-4.703-1.14a.627.627 0 0 0-.742.487c-.324 1.776-.236 3.6.234 5.332.06.226.244.396.473.44.23.043.461-.047.6-.237l2.91-3.956a.625.625 0 0 0-.056-.77.627.627 0 0 0-.716-.156zm1.524-3.647L4.302 9.942a.627.627 0 0 0-.845.109c-1.097 1.464-1.79 3.2-2.001 5.013a.625.625 0 0 0 .613.694l4.86-.005c.27 0 .505-.172.59-.428l.023-.069a.625.625 0 0 0-.34-.725zm4.386-8.02c-1.812.21-3.548.904-5.013 2.001a.625.625 0 0 0-.109.845l3.009 4.208c.16.224.444.317.703.232l.069-.023c.256-.086.428-.32.428-.59V4.622a.625.625 0 0 0-.694-.613l.607.912zm4.47 0a.625.625 0 0 0-.694.613v4.948c0 .27.172.504.428.59l.069.023c.259.085.543-.008.703-.232l3.009-4.208a.625.625 0 0 0-.109-.845c-1.465-1.097-3.2-1.79-5.013-2.001l.607-.888z"/></svg>
              Yelp — Clark Handy Solutions
            </a>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="md:col-span-3 section-fade">
        <div class="bg-white rounded-2xl border border-[#EDE5D4] p-8 md:p-10 shadow-sm">
          <h2 class="font-['Playfair_Display'] text-3xl font-bold text-[#1E1208] mb-2">Send a Message</h2>
          <p class="text-[#7A6652] text-sm mb-8">We'll get back to you as soon as possible — usually within a few hours.</p>

          <!-- NOTE: Replace action URL with a real form handler (Formspree, Netlify Forms, etc.) -->
          <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-5">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-xs font-semibold tracking-widest uppercase text-[#7A6652] mb-2">First Name</label>
                <input type="text" name="first_name" required placeholder="John"
                  class="w-full px-4 py-3 rounded-xl border border-[#EDE5D4] bg-[#FAF7F2] text-[#1E1208] text-sm focus:outline-none focus:border-[#C46A1F] focus:ring-1 focus:ring-[#C46A1F] transition-colors placeholder-[#7A6652]/50" />
              </div>
              <div>
                <label class="block text-xs font-semibold tracking-widest uppercase text-[#7A6652] mb-2">Last Name</label>
                <input type="text" name="last_name" required placeholder="Smith"
                  class="w-full px-4 py-3 rounded-xl border border-[#EDE5D4] bg-[#FAF7F2] text-[#1E1208] text-sm focus:outline-none focus:border-[#C46A1F] focus:ring-1 focus:ring-[#C46A1F] transition-colors placeholder-[#7A6652]/50" />
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold tracking-widest uppercase text-[#7A6652] mb-2">Email</label>
              <input type="email" name="email" required placeholder="john@email.com"
                class="w-full px-4 py-3 rounded-xl border border-[#EDE5D4] bg-[#FAF7F2] text-[#1E1208] text-sm focus:outline-none focus:border-[#C46A1F] focus:ring-1 focus:ring-[#C46A1F] transition-colors placeholder-[#7A6652]/50" />
            </div>

            <div>
              <label class="block text-xs font-semibold tracking-widest uppercase text-[#7A6652] mb-2">Phone (optional)</label>
              <input type="tel" name="phone" placeholder="(714) 555-0123"
                class="w-full px-4 py-3 rounded-xl border border-[#EDE5D4] bg-[#FAF7F2] text-[#1E1208] text-sm focus:outline-none focus:border-[#C46A1F] focus:ring-1 focus:ring-[#C46A1F] transition-colors placeholder-[#7A6652]/50" />
            </div>

            <div>
              <label class="block text-xs font-semibold tracking-widest uppercase text-[#7A6652] mb-2">Service Needed</label>
              <select name="service"
                class="w-full px-4 py-3 rounded-xl border border-[#EDE5D4] bg-[#FAF7F2] text-[#1E1208] text-sm focus:outline-none focus:border-[#C46A1F] focus:ring-1 focus:ring-[#C46A1F] transition-colors">
                <option value="">Select a service...</option>
                <option>Plumbing</option>
                <option>Electrical</option>
                <option>Door Installation</option>
                <option>Painting</option>
                <option>Junk Removal & Hauling</option>
                <option>Drywall</option>
                <option>Flooring Installation</option>
                <option>Interior Trim</option>
                <option>Other / Not Sure</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-semibold tracking-widest uppercase text-[#7A6652] mb-2">Message</label>
              <textarea name="message" rows="4" required placeholder="Tell us about your project..."
                class="w-full px-4 py-3 rounded-xl border border-[#EDE5D4] bg-[#FAF7F2] text-[#1E1208] text-sm focus:outline-none focus:border-[#C46A1F] focus:ring-1 focus:ring-[#C46A1F] transition-colors placeholder-[#7A6652]/50 resize-none"></textarea>
            </div>

            <button type="submit"
              class="w-full bg-[#C46A1F] hover:bg-[#E08030] text-white font-semibold py-4 rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-amber-900/20 hover:-translate-y-0.5 text-sm tracking-wide">
              Send Message →
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

</Layout>