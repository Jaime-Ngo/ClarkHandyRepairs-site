---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">

  <!-- HERO -->
  <section class="hero">
    <img class="hero-bg" src="/images/hero-bg.jpg" alt="Clark Handy Solutions — professional handyman services" />
    <div class="hero-overlay"></div>
    <div class="hero-content container">
      <span class="section-eyebrow fade-up delay-1">Orange County's Trusted Handyman</span>
      <h1 class="fade-up delay-2">Solutions<br /><span>Begin Here.</span></h1>      <p class="hero-sub fade-up delay-3">From plumbing and electrical to painting and flooring, Clark Handy Solutions handles it all with skill, speed, and integrity.</p>
      <div class="hero-btns fade-up delay-4">
        <a href="/contact" class="btn btn-gold">Get a Free Quote</a>
        <a href="/services" class="btn btn-outline">View Services</a>
      </div>
    </div>
    <div class="hero-scroll-indicator">
      <span></span>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about-section">
    <div class="container about-grid">
      <div class="about-image-wrap">
        <img class="about-img" src="/images/about-oscar.jpg" alt="Oscar Clark — Clark Handy Solutions" />
        <div class="about-img-accent"></div>
      </div>
      <div class="about-text">
        <span class="section-eyebrow">Who We Are</span>
        <div class="gold-line"></div>
        <h2 class="section-title">Your Neighborhood<br />Problem Solver</h2>
        <p class="section-body">Clark Handy Solutions prides itself on a work ethic designed to bring quality services into the homes of local neighborhoods. Flexible pricing is meant to communicate the desire for a business relationship rather than a series of financial transactions. Attention to detail is key because it's the little things that matter in the grand scheme of things. Every problem has a solution, and solutions lie in wait for those who are eager to figure them out. The importance of home is well understood, giving a greater meaning to the industry of service. I accept the challenge in making customer satisfaction more than a possibility.

        </p>
        <p class="section-body" style="margin-top: 1rem;">Based in Orange County and proudly serving the surrounding area, we bring professional-grade skills to jobs of every size.</p>
        <div class="about-actions">
          <a href="/contact" class="btn btn-gold">Work With Us</a>
          <a href="/portfolio" class="btn btn-outline">See Our Work</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES PREVIEW -->
  <section class="services-preview">
    <div class="container">
      <div class="services-header">
        <div>
          <span class="section-eyebrow">What We Do</span>
          <div class="gold-line"></div>
          <h2 class="section-title">A Full Range of<br />Home Services</h2>
        </div>
        <a href="/services" class="btn btn-outline-gold">All Services</a>
      </div>
      <div class="services-grid">
        <a href="/services#plumbing" class="service-card">
          <img class="service-card-img" src="/images/service-plumbing.jpg" alt="Plumbing services" />
          <div class="service-card-body">
            <h3>Plumbing</h3>
            <p>Faucets, toilets, sinks, drain clogs, shower valves & more.</p>
            <span class="service-card-link">Learn More →</span>
          </div>
        </a>
        <a href="/services#electrical" class="service-card">
          <img class="service-card-img" src="/images/service-electrical.jpg" alt="Electrical services" />
          <div class="service-card-body">
            <h3>Electrical</h3>
            <p>Light fixtures, outlets, ceiling fans, panel upgrades & more.</p>
            <span class="service-card-link">Learn More →</span>
          </div>
        </a>
        <a href="/services#painting" class="service-card">
          <img class="service-card-img" src="/images/service-painting.jpg" alt="Painting services" />
          <div class="service-card-body">
            <h3>Painting</h3>
            <p>Interior painting with patching, sanding, and caulking included.</p>
            <span class="service-card-link">Learn More →</span>
          </div>
        </a>
        <a href="/services#flooring" class="service-card">
          <img class="service-card-img" src="/images/service-flooring.jpg" alt="Flooring services" />
          <div class="service-card-body">
            <h3>Flooring</h3>
            <p>Laminate and plank flooring installation and removal.</p>
            <span class="service-card-link">Learn More →</span>
          </div>
        </a>
        <a href="/services#drywall" class="service-card">
          <img class="service-card-img" src="/images/service-drywall.jpg" alt="Drywall services" />
          <div class="service-card-body">
            <h3>Drywall</h3>
            <p>Installation, patching, texturing, and painting options.</p>
            <span class="service-card-link">Learn More →</span>
          </div>
        </a>
        <a href="/services#smarthome" class="service-card">
          <img class="service-card-img" src="/images/service-smarthome.jpg" alt="Smart home services" />
          <div class="service-card-body">
            <h3>Smart Home</h3>
            <p>TV mounting, smart devices, cameras, and doorbells.</p>
            <span class="service-card-link">Learn More →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="reviews-section">
    <div class="container">
      <div style="text-align: center; margin-bottom: 3.5rem; display: block; width: 100%;">
        <span style="font-family: var(--font-cond); font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 1rem;">What Clients Say</span>
        <h2 style="font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 4rem); line-height: 0.95; letter-spacing: 0.02em; color: var(--light); margin: 0;">Real Work.<br />Real Results.</h2>
      </div>
      <div class="reviews-grid">

        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <p class="review-body">"Oscar does amazing work! He installed my chandelier and kitchen sink and I could not be happier with the results. His attention to detail is second to none. I would highly recommend him to anybody."</p>
          <div class="review-author">
            <div class="review-avatar" style="background:#9e9e9e;">M</div>
            <div>
              <span class="review-name">Michael Mulcahy</span>
              <span class="review-source">Google Review</span>
            </div>
          </div>
        </div>

        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <p class="review-body">"I had a nagging leak in my small bathroom shower for months. It was time to take care of the problem before it becomes a bigger issue. I called Oscar C. to repair the leak and replace the cartridge for my Delta Tub/Shower. Oscar was very professional, courteous and efficient. He came in and assessed the leak and went right to work. Oscar immediately checked if the cartridge I supplied to him will fit. It was too big. Oscar found a cartridge at the local hardware store. Once he returned it was smooth transition to repair the cartridge and clean up and make sure it was done properly. Magnificent job!"</p>
          <div class="review-author">
            <div class="review-avatar" style="background:#5c6bc0;">W</div>
            <div>
              <span class="review-name">Wayne Rayford</span>
              <span class="review-source">Google Review</span>
            </div>
          </div>
        </div>

        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <p class="review-body">"Excellent service and genuine care for the client are Oscar's gifts! He was thorough and meticulous in putting together 2 bookcases and a entertainment center and QUICK! I really expected a 2 day job...he got it all done in 4 and half hours! I will definitely call on him again!"</p>
          <div class="review-author">
            <div class="review-avatar" style="background:#e91e8c;">C</div>
            <div>
              <span class="review-name">Chrisanne Blankenship</span>
              <span class="review-source">Google Review</span>
            </div>
          </div>
        </div>

      </div>
      <div class="reviews-cta">
        <a href="https://www.google.com/search?q=Clark+Handy+Solutions+reviews" target="_blank" rel="noopener noreferrer" class="btn btn-outline-gold">See All Reviews</a>
      </div>
    </div>
  </section>

  <!-- PORTFOLIO TEASER -->
  <section class="portfolio-teaser">
    <div class="container">
      <div class="portfolio-header">
        <span class="section-eyebrow">Our Work</span>
        <div class="gold-line"></div>
        <h2 class="section-title">Results That Speak<br />For Themselves</h2>
      </div>
      <div class="portfolio-grid">
        <img class="portfolio-item" src="/images/home-portfolio-01.jpg" alt="Project photo" />
        <img class="portfolio-item" src="/images/home-portfolio-02.jpg" alt="Project photo" />
        <img class="portfolio-item" src="/images/home-portfolio-03.jpg" alt="Project photo" />
      </div>
      <div style="text-align:center; margin-top: 3rem;">
        <a href="/portfolio" class="btn btn-outline-gold">View Full Portfolio</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ─── HERO ─── */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 640px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0,0,0,0.82) 0%,
      rgba(0,0,0,0.5) 60%,
      rgba(0,0,0,0.7) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: var(--nav-h);
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(4rem, 10vw, 8rem);
    line-height: 0.92;
    letter-spacing: 0.02em;
    color: var(--light);
    margin-bottom: 1.5rem;
  }
  .hero h1 span { color: var(--gold); }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--light-dim);
    max-width: 500px;
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .hero-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }
  .hero-scroll-indicator span {
    display: block;
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    margin: 0 auto;
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* ─── ABOUT ─── */
  .about-section {
    padding: 7rem 0;
    background: var(--dark);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .about-image-wrap {
    position: relative;
    height: 520px;
  }

  .about-img {
    position: absolute;
    inset: 0;
    border-radius: 2px;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-img-accent {
    position: absolute;
    bottom: -16px;
    right: -16px;
    width: calc(100% - 32px);
    height: calc(100% - 32px);
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 2px;
    z-index: 0;
  }

  .about-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2.5rem;
  }

  @media (max-width: 860px) {
    .about-grid { grid-template-columns: 1fr; }
    .about-image-wrap { height: 340px; }
  }

  /* ─── SERVICES PREVIEW ─── */
  .services-preview {
    padding: 7rem 0;
    background: var(--dark-2);
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .services-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3.5rem;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: var(--gold-dim);
    border: 1px solid var(--gold-dim);
  }

  .service-card {
    background: var(--dark-3);
    display: flex;
    flex-direction: column;
    transition: background 0.25s;
    text-decoration: none;
    color: inherit;
  }
  .service-card:hover { background: var(--mid); }
  .service-card:hover .service-card-link { color: var(--gold-light); }

  .service-card-img {
    height: 200px;
    width: 100%;
    object-fit: cover;
  }

  .service-card-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .service-card-body h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.04em;
    color: var(--light);
    margin-bottom: 0.5rem;
  }

  .service-card-body p {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
  }

  .service-card-link {
    display: block;
    margin-top: 1rem;
    font-family: var(--font-cond);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    transition: color 0.2s;
  }

  @media (max-width: 860px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .services-grid { grid-template-columns: 1fr; }
  }

  /* ─── REVIEWS ─── */
  .reviews-section {
    padding: 7rem 0;
    background: var(--dark);
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .reviews-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .reviews-eyebrow {
    font-family: var(--font-cond);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 1rem;
  }

  .reviews-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    color: var(--light);
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .review-card {
    background: var(--dark-2);
    border: 1px solid rgba(201,168,76,0.12);
    border-radius: 4px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .review-stars {
    color: var(--gold);
    font-size: 1rem;
    letter-spacing: 0.1em;
  }

  .review-body {
    font-size: 0.9rem;
    color: var(--light-dim);
    line-height: 1.75;
    flex: 1;
    font-style: italic;
  }

  .review-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
  }

  .review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
    flex-shrink: 0;
  }

  .review-name {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--light);
  }

  .review-source {
    display: block;
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 0.15rem;
  }

  .reviews-cta {
    text-align: center;
    margin-top: 3rem;
  }

  @media (max-width: 860px) {
    .reviews-grid { grid-template-columns: 1fr; }
  }

  /* ─── PORTFOLIO TEASER ─── */
  .portfolio-teaser {
    padding: 7rem 0;
    background: var(--dark-2);
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .portfolio-header {
    margin-bottom: 3rem;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 300px;
    gap: 6px;
  }

  .portfolio-item {
    border-radius: 1px;
    object-fit: cover;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 768px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .portfolio-item { height: 220px; }
  }
</style>